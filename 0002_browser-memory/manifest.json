{
  "manifest_version": 3,
  "name": "Browser Memory",
  "version": "0.1.0",
  "description": "Save pages and search them later (local-only)",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}
